---
import NavLayout from '../../layouts/NavLayout.astro'
import BlogPage from '../../components/Page/BlogPage.vue'
import { VContainer } from '@overgaming/vicius'
import t from '../../translations'
import { toBlog } from '../../router'
import { getPosts } from '../../data'

const siteUrl = import.meta.env.PUBLIC_SITE_URL
const author = import.meta.env.PUBLIC_SITE_NAME
const lang = import.meta.env.PUBLIC_LANG

const posts = getPosts()

const schema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: t('page.blog.h1'),
  description: t('page.blog.description'),
  url: `${siteUrl}${toBlog()}`,
  publisher: {
    '@type': 'Organization',
    name: author,
    url: siteUrl,
    logo: {
      '@type': 'ImageObject',
      url: `${siteUrl}/assets/logo/${lang}.webp`
    }
  },
  blogPost: posts.map(post => ({
    '@type': 'BlogPosting',
    headline: post.title,
    description: post.description,
    datePublished: post.date,
    publisher: {
      '@type': 'Organization',
      name: author,
      logo: {
        '@type': 'ImageObject',
        url: `${siteUrl}/assets/logo/${lang}.webp`
      }
    }
  }))
})
---

<NavLayout
  title={t('page.blog.h1')}
  description={t('page.blog.description')}
  url={toBlog()}
  image={`/assets/logo/${lang}.webp`}
>
  <VContainer size="xl" class="blog-header">
    <h1 class="blog-header__title">{t('page.blog.h1')}</h1>
    <p class="blog-header__description">{t('page.blog.description')}</p>
  </VContainer>

  <BlogPage client:load />

  <script type="application/ld+json" is:inline set:html={schema} />
</NavLayout>

<style>
  .blog-header {
    padding: var(--v-unit-8) var(--v-unit-4) var(--v-unit-6);
    text-align: center;
  }

  .blog-header__title {
    font-size: clamp(32px, 5vw, 48px);
    font-weight: 700;
    color: var(--v-color-text-high);
    margin: 0 0 var(--v-unit-3) 0;
    line-height: 1.2;
  }

  .blog-header__description {
    font-size: clamp(16px, 2vw, 20px);
    color: var(--v-color-text-medium);
    margin: 0;
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.6;
  }

  @media (max-width: 768px) {
    .blog-header {
      padding: var(--v-unit-6) var(--v-unit-2) var(--v-unit-4);
    }

    .blog-header__title {
      font-size: 28px;
    }

    .blog-header__description {
      font-size: 14px;
    }
  }
</style>
